  "zhang_xing": {
    "火型掌": "掌形尖长，手指纤细。性格热情冲动，思维敏捷，富有创造力。易急躁，情绪波动大。宜从事艺术、创意、演艺类工作。",
    "水型掌": "掌形圆润，手软肉厚。性格温和包容，善解人意，情感丰富。适应力强，但易优柔寡断。宜从事服务、咨询、护理类工作。",
    "木型掌": "掌形方正，手指修长。性格正直仁慈，有主见，追求理想。固执己见，不善变通。宜从事教育、研究、技术类工作。",
    "金型掌": "掌形方正坚实，指节分明。性格刚毅果断，重原则，讲信誉。过于严肃，缺乏柔情。宜从事管理、金融、法律类工作。",
    "土型掌": "掌形厚实宽大，掌纹粗深。性格稳重踏实，勤劳肯干，重实际。思维较慢，不善表达。宜从事农业、建筑、实业类工作。"
  },
  "main_lines": {
