  "aux_lines": {
    "事业线": {
      "清晰直上": "事业顺利，步步高升，有明确目标。",
      "断续": "事业多变动，跳槽频繁，或中年后转行。",
      "浅淡": "事业心不强，或工作平平，缺乏野心。",
