    "智慧线": {
      "深长清晰": "思维敏捷，头脑聪明，逻辑性强。",
      "短": "思维直接，注重实际，不喜复杂思考。",
      "过长": "思虑过多，易钻牛角尖，精神压力大。",
      "断裂": "思维模式有突变，或曾受精神打击。",
      "分叉": "多才多艺，兴趣广泛，或同时从事多种工作。",
